+/**
+ * @file
+ *
+ *  PassthroughStage is a simple pipeline stage that forwards
+ *  ForwardInstData from its input to its output without modification.
+ *  It is used to model additional pipeline depth (e.g. Decode1, Issue,
+ *  Memory, Writeback) in the 8-stage Lumi-Core pipeline configuration.
+ */
+
+#ifndef __CPU_MINOR_PASSTHROUGH_HH__
+#define __CPU_MINOR_PASSTHROUGH_HH__
+
+#include <vector>
+
+#include "base/named.hh"
+#include "cpu/minor/buffers.hh"
+#include "cpu/minor/cpu.hh"
+#include "cpu/minor/dyn_inst.hh"
+#include "cpu/minor/pipe_data.hh"
+
+namespace gem5
+{
+
+namespace minor
+{
+
+/**
+ * PassthroughStage receives ForwardInstData from a preceding stage and
+ * forwards it unchanged to the next stage.  It models an additional
+ * pipeline register / delay stage without altering instruction semantics.
+ *
+ * Used to extend MinorCPU from 4 to 8 pipeline stages (Cortex-R82 model).
+ *
+ * Terminal mode (isTerminal=true): the stage consumes input without
+ * producing output.  Used for the Writeback stage which is the last
+ * stage in the pipeline.
+ */
+class PassthroughStage : public Named
+{
+  protected:
+    /** Pointer back to the containing CPU */
+    MinorCPU &cpu;
+
+    /** Input port: data from the preceding stage */
+    Latch<ForwardInstData>::Output inp;
+
+    /** Output wire for non-terminal stages; nullptr for terminal. */
+    typename Latch<ForwardInstData>::Buffer::wire outWire;
+
+    /** If true, this is the last stage and has no output */
+    bool isTerminal;
+
+    /** Interface to reserve space in the next stage.
+     *  nullptr for terminal stages. */
+    std::vector<InputBuffer<ForwardInstData>> *nextStageReserve;
+
+    /** Width of output in instructions per cycle */
+    unsigned int outputWidth;
+
+  public:
+    /** Public so that Pipeline can pass it to the preceding stage */
+    std::vector<InputBuffer<ForwardInstData>> inputBuffer;
+
+  protected:
+    /** Per-thread state (minimal - just tracking blocked status) */
+    struct PassthroughThreadInfo
+    {
+        bool blocked = false;
+    };
+
+    std::vector<PassthroughThreadInfo> stageInfo;
+    ThreadID threadPriority;
+
+  protected:
+    /** Get input data or nullptr if none available */
+    const ForwardInstData *getInput(ThreadID tid);
+
+    /** Pop an element off the input buffer */
+    void popInput(ThreadID tid);
+
+    /** Determine next thread to process */
+    ThreadID getScheduledThread();
+
+  public:
+    /** Standard constructor for non-terminal stages */
+    PassthroughStage(const std::string &name,
+        MinorCPU &cpu_,
+        const BaseMinorCPUParams &params,
+        Latch<ForwardInstData>::Output inp_,
+        Latch<ForwardInstData>::Input out_,
+        std::vector<InputBuffer<ForwardInstData>> &next_stage_input_buffer,
+        unsigned int input_buffer_size,
+        unsigned int width);
+
+    /** Constructor for terminal stages (no output, e.g. Writeback) */
+    PassthroughStage(const std::string &name,
+        MinorCPU &cpu_,
+        const BaseMinorCPUParams &params,
+        Latch<ForwardInstData>::Output inp_,
+        unsigned int input_buffer_size,
+        unsigned int width);
+
+  public:
+    /** Forward data from input to output */
+    void evaluate();
+
+    void minorTrace() const;
+
+    /** A passthrough stage is drained when its input buffer is empty */
+    bool isDrained();
+};
+
+} // namespace minor
+} // namespace gem5
+
+#endif /* __CPU_MINOR_PASSTHROUGH_HH__ */
