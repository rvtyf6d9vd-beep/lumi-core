+bool
+PMP::smepmpCheckMMode(BaseMMU::Mode mode, bool locked,
+                       uint8_t this_cfg) const
+{
+    // Smepmp MML=1, MMWP=0: Locked entries grant access to M-mode for
+    // read (R), execute (X) if the corresponding bit is set.
+    // Writes are forbidden regardless of W bit on locked entries.
+    // Unlocked entries are treated as if they don't exist for M-mode.
+    if ((mseccfg & MSECCFG_MML) && !(mseccfg & MSECCFG_MMWP)) {
+        if (!locked)
+            return false; // Unlocked entries: no M-mode access
+        if (mode == BaseMMU::Mode::Write)
+            return false; // Writes forbidden on locked entries
+        if ((mode == BaseMMU::Mode::Read) && (PMP_READ & this_cfg))
+            return true;
+        if ((mode == BaseMMU::Mode::Execute) && (PMP_EXEC & this_cfg))
+            return true;
+        return false;
+    }
+
+    // Smepmp MML=0, MMWP=1: M-mode writes to any region are forbidden.
+    // Reads and execs proceed with normal PMP permission check.
+    if ((mseccfg & MSECCFG_MMWP) && !(mseccfg & MSECCFG_MML)) {
+        if (mode == BaseMMU::Mode::Write)
+            return false;
+        return true; // Read/exec: let caller check permissions
+    }
+
+    // Smepmp MML=1, MMWP=1: Maximum restriction.
+    // Reads locked readable, execs locked executable, writes always denied.
+    if ((mseccfg & (MSECCFG_MML | MSECCFG_MMWP)) ==
+        (MSECCFG_MML | MSECCFG_MMWP)) {
+        if (!locked)
+            return false; // Unlocked entries: no M-mode access
+        if (mode == BaseMMU::Mode::Write)
+            return false;
+        if ((mode == BaseMMU::Mode::Read) && (PMP_READ & this_cfg))
+            return true;
+        if ((mode == BaseMMU::Mode::Execute) && (PMP_EXEC & this_cfg))
+            return true;
+        return false;
+    }
+
+    // No Smepmp restrictions: proceed to normal PMP check
+    return true;
+}
+
 } // namespace RiscvISA
 } // namespace gem5
