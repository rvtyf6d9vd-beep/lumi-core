new file mode 100644
index 0000000..b9445f1
--- /dev/null
+++ b/src/arch/riscv/clic.hh
@@ -0,0 +1,171 @@
+/*
+ * Copyright (c) 2024 Lumi-Core Project
+ * All rights reserved.
+ *
+ * CLIC (Core-Local Interrupt Controller) implementation for Lumi-Core.
+ * Based on RISC-V CLIC specification.
+ */
+
+#ifndef __ARCH_RISCV_CLIC_HH__
+#define __ARCH_RISCV_CLIC_HH__
+
+#include <cstdint>
+#include <vector>
+
+#include "base/types.hh"
+#include "cpu/thread_context.hh"
+#include "params/CLIC.hh"
+#include "sim/sim_object.hh"
+
+namespace gem5
+{
+
+class ThreadContext;
+
+namespace RiscvISA
+{
+
+// Forward declaration
+class FaultBase;
+
+/**
+ * CLIC interrupt state for one interrupt input.
+ */
+struct ClicInterruptState
+{
+    /** Interrupt source ID (0 to num_interrupts-1) */
+    uint32_t id;
+
+    /** CLIC level (0-63, 0 = no level/edge triggered) */
+    uint8_t level;
+
+    /** Pending flag */
+    uint8_t pending;
+
+    /** Enable flag */
+    uint8_t enable;
+};
+
+/**
+ * Core-Local Interrupt Controller (CLIC) model.
+ *
+ * Implements the RISC-V CLIC specification for Lumi-Core:
+ * - Up to 240 interrupt inputs with 64-level priority
+ * - Programmable vectoring via mtvt register
+ * - Interrupt threshold (mintthresh)
+ * - Nested preemption based on interrupt levels
+ * - Scratch register swap (mscratchcsw/mscratchcswl)
+ */
+class CLIC : public SimObject
+{
+  private:
+    /** Number of interrupt inputs */
+    int numInterrupts;
+
+    /** CLIC vector table base (from CSR_MTVT) */
+    Addr vectorBase;
+
+    /** CLIC interrupt threshold */
+    uint8_t mintthresh;
+
+    /** Machine interrupt level (current priority) */
+    uint8_t mil;
+
+    /** Machine vector interrupt enable */
+    bool mvie;
+
+    /** Machine non-vectored mode */
+    bool mnvec;
+
+    /** Per-interrupt state */
+    std::vector<ClicInterruptState> interrupts;
+
+    /** Currently selected highest priority interrupt ID */
+    int currentSelectedId;
+
+    /** Priority level of the currently serviced interrupt */
+    uint8_t currentLevel;
+
+  public:
+    using Params = CLICParams;
+
+    CLIC(const Params &params);
+
+    /**
+     * Post an interrupt with the given priority.
+     * @param id Interrupt source ID (0 to numInterrupts-1)
+     * @param priority Priority level (0-63)
+     */
+    void postInterrupt(uint32_t id, uint8_t priority = 0);
+
+    /**
+     * Clear a pending interrupt.
+     * @param id Interrupt source ID
+     */
+    void clearInterrupt(uint32_t id);
+
+    /**
+     * Read a CLIC CSR register.
+     * @param misc_reg_idx Misc register index (MiscRegIndex)
+     * @param val Output value
+     * @return true if the CSR was handled, false otherwise
+     */
+    bool readCSR(int misc_reg_idx, RegVal &val) const;
+
+    /**
+     * Write a CLIC CSR register.
+     * @param misc_reg_idx Misc register index (MiscRegIndex)
+     * @param val Value to write
+     * @return true if the CSR was handled, false otherwise
+     */
+    bool writeCSR(int misc_reg_idx, RegVal val);
+
+    /**
+     * Arbitrate among pending interrupts and return the winning ID.
+     * @return Interrupt ID of highest priority pending interrupt, or -1 if none
+     */
+    int arbitrate();
+
+    /**
+     * Get the vector target address for the given interrupt ID.
+     * @param id Interrupt source ID
+     * @return Target PC address
+     */
+    Addr getVectorAddress(int id) const;
+
+    /**
+     * Get the current machine interrupt level.
+     */
+    uint8_t getMil() const { return mil; }
+
+    /**
+     * Set the machine interrupt level (called when entering/exiting ISR).
+     */
+    void setMil(uint8_t level) { mil = level; }
+
+    /**
+     * Get whether CLIC non-vectored mode is active.
+     */
+    bool isMnvec() const { return mnvec; }
+
+    /**
+     * Get vector base address.
+     */
+    Addr getVectorBase() const { return vectorBase; }
+
+    /**
+     * Check if an interrupt with given priority can preempt current context.
+     */
+    bool canPreempt(uint8_t priority) const
+    {
+        return priority > mintthresh && priority > mil;
+    }
+
+    void serialize(CheckpointOut &cp) const override;
+    void unserialize(CheckpointIn &cp) override;
+};
+
+} // namespace RiscvISA
+} // namespace gem5
+
+#endif // __ARCH_RISCV_CLIC_HH__
