diff --git a/src/arch/riscv/clic.cc b/src/arch/riscv/clic.cc
new file mode 100644
index 0000000..1eaaa17
--- /dev/null
+++ b/src/arch/riscv/clic.cc
@@ -0,0 +1,230 @@
+/*
+ * Copyright (c) 2024 Lumi-Core Project
+ * All rights reserved.
+ *
+ * CLIC (Core-Local Interrupt Controller) implementation for Lumi-Core.
+ */
+
+#include "arch/riscv/clic.hh"
+
+#include "base/logging.hh"
+#include "base/bitfield.hh"
+#include "debug/Interrupt.hh"
+
+namespace gem5
+{
+
+namespace RiscvISA
+{
+
+// Local CLIC CSR indices matching MiscRegIndex in regs/misc.hh.
+// Calculated from misc.hh enum: MTVT=133, MNVEC=134, MINTSTATUS=135,
+// MINTTHRESH=136, MSCRATCHCSW=137, MSCRATCHCSWL=138
+enum {
+    CLIC_MISCREG_MTVT        = 133,
+    CLIC_MISCREG_MNVEC       = 134,
+    CLIC_MISCREG_MINTSTATUS  = 135,
+    CLIC_MISCREG_MINTTHRESH  = 136,
+    CLIC_MISCREG_MSCRATCHCSW = 137,
+    CLIC_MISCREG_MSCRATCHCSWL= 138,
+};
+
+CLIC::CLIC(const Params &params)
+    : SimObject(params),
+      numInterrupts(params.num_interrupts),
+      vectorBase(0),
+      mintthresh(0),
+      mil(0),
+      mvie(false),
+      mnvec(false),
+      currentSelectedId(-1),
+      currentLevel(0)
+{
+    // Validate interrupt count
+    panic_if(numInterrupts < 1 || numInterrupts > 240,
+             "CLIC: num_interrupts must be between 1 and 240");
+
+    // Initialize interrupt state array
+    interrupts.resize(numInterrupts);
+    for (int i = 0; i < numInterrupts; i++) {
+        interrupts[i].id = i;
+        interrupts[i].level = 0;
+        interrupts[i].pending = 0;
+        interrupts[i].enable = 0;
+    }
+}
+
+void
+CLIC::postInterrupt(uint32_t id, uint8_t priority)
+{
+    if (id >= numInterrupts) {
+        warn("CLIC: ignoring interrupt post for out-of-range ID %u\n", id);
+        return;
+    }
+
+    DPRINTF(Interrupt, "CLIC: post interrupt %u, priority %u\n", id, priority);
+
+    interrupts[id].pending = 1;
+    if (priority > 0) {
+        interrupts[id].level = priority;
+    }
+}
+
+void
+CLIC::clearInterrupt(uint32_t id)
+{
+    if (id >= numInterrupts) {
+        warn("CLIC: ignoring interrupt clear for out-of-range ID %u\n", id);
+        return;
+    }
+
+    DPRINTF(Interrupt, "CLIC: clear interrupt %u\n", id);
+    interrupts[id].pending = 0;
+}
+
+int
+CLIC::arbitrate()
+{
+    int bestId = -1;
+    uint8_t bestPriority = 0;
+
+    for (int i = 0; i < numInterrupts; i++) {
+        if (interrupts[i].pending && interrupts[i].level > mintthresh &&
+            interrupts[i].level > mil) {
+            if (interrupts[i].level > bestPriority ||
+                (interrupts[i].level == bestPriority && i < bestId)) {
+                bestPriority = interrupts[i].level;
+                bestId = i;
+            }
+        }
+    }
+
+    currentSelectedId = bestId;
+    if (bestId >= 0) {
+        currentLevel = bestPriority;
+    }
+
+    return bestId;
+}
+
+Addr
+CLIC::getVectorAddress(int id) const
+{
+    if (mnvec) {
+        // Non-vectored mode: all interrupts go to base address
+        return vectorBase;
+    }
+
+    // Vectored mode: vectorBase + id * 4
+    // Each vector entry is 4 bytes (one instruction or address)
+    return vectorBase + id * 4;
+}
+
+bool
+CLIC::readCSR(int misc_reg_idx, RegVal &val) const
+{
+    switch (misc_reg_idx) {
+      case CLIC_MISCREG_MTVT:
+        val = vectorBase;
+        return true;
+      case CLIC_MISCREG_MNVEC:
+        val = mnvec ? 1 : 0;
+        return true;
+      case CLIC_MISCREG_MINTSTATUS:
+        val = ((RegVal)mil << 16) | (mvie ? (1 << 8) : 0) | (mnvec ? 1 : 0);
+        return true;
+      case CLIC_MISCREG_MINTTHRESH:
+        val = mintthresh;
+        return true;
+      case CLIC_MISCREG_MSCRATCHCSW:
+      case CLIC_MISCREG_MSCRATCHCSWL:
+        // Write-only CSRs, reading returns 0
+        val = 0;
+        return true;
+      default:
+        val = 0;
+        return false;
+    }
+}
+
+bool
+CLIC::writeCSR(int misc_reg_idx, RegVal val)
+{
+    switch (misc_reg_idx) {
+      case CLIC_MISCREG_MTVT:
+        vectorBase = bits(val, 63, 2) << 2;
+        return true;
+      case CLIC_MISCREG_MNVEC:
+        mnvec = (val & 1) != 0;
+        return true;
+      case CLIC_MISCREG_MINTSTATUS:
+        mil = (val >> 16) & 0x3F;
+        return true;
+      case CLIC_MISCREG_MINTTHRESH:
+        mintthresh = val & 0x3F;
+        return true;
+      case CLIC_MISCREG_MSCRATCHCSW:
+      case CLIC_MISCREG_MSCRATCHCSWL:
+        return true;
+      default:
+        return false;
+    }
+}
+
+void
+CLIC::serialize(CheckpointOut &cp) const
+{
+    SERIALIZE_SCALAR(numInterrupts);
+    SERIALIZE_SCALAR(vectorBase);
+    SERIALIZE_SCALAR(mintthresh);
+    SERIALIZE_SCALAR(mil);
+    SERIALIZE_SCALAR(mvie);
+    SERIALIZE_SCALAR(mnvec);
+    SERIALIZE_SCALAR(currentSelectedId);
+    SERIALIZE_SCALAR(currentLevel);
+
+    // Serialize interrupt states
+    std::vector<uint8_t> pendingBits(numInterrupts);
+    std::vector<uint8_t> levelBits(numInterrupts);
+    std::vector<uint8_t> enableBits(numInterrupts);
+    for (int i = 0; i < numInterrupts; i++) {
+        pendingBits[i] = interrupts[i].pending;
+        levelBits[i] = interrupts[i].level;
+        enableBits[i] = interrupts[i].enable;
+    }
+    SERIALIZE_CONTAINER(pendingBits);
+    SERIALIZE_CONTAINER(levelBits);
+    SERIALIZE_CONTAINER(enableBits);
+}
+
+void
+CLIC::unserialize(CheckpointIn &cp)
+{
+    UNSERIALIZE_SCALAR(numInterrupts);
+    UNSERIALIZE_SCALAR(vectorBase);
+    UNSERIALIZE_SCALAR(mintthresh);
+    UNSERIALIZE_SCALAR(mil);
+    UNSERIALIZE_SCALAR(mvie);
+    UNSERIALIZE_SCALAR(mnvec);
+    UNSERIALIZE_SCALAR(currentSelectedId);
+    UNSERIALIZE_SCALAR(currentLevel);
+
+    // Restore interrupt states
+    std::vector<uint8_t> pendingBits(numInterrupts);
+    std::vector<uint8_t> levelBits(numInterrupts);
+    std::vector<uint8_t> enableBits(numInterrupts);
+    UNSERIALIZE_CONTAINER(pendingBits);
+    UNSERIALIZE_CONTAINER(levelBits);
+    UNSERIALIZE_CONTAINER(enableBits);
+
+    interrupts.resize(numInterrupts);
+    for (int i = 0; i < numInterrupts; i++) {
+        interrupts[i].id = i;
+        interrupts[i].pending = pendingBits[i];
+        interrupts[i].level = levelBits[i];
+        interrupts[i].enable = enableBits[i];
+    }
+}
+
+} // namespace RiscvISA
+} // namespace gem5
