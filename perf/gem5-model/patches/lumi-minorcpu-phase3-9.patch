+
+PassthroughStage::PassthroughStage(const std::string &name,
+    MinorCPU &cpu_,
+    const BaseMinorCPUParams &params,
+    Latch<ForwardInstData>::Output inp_,
+    Latch<ForwardInstData>::Input out_,
+    std::vector<InputBuffer<ForwardInstData>> &next_stage_input_buffer,
+    unsigned int input_buffer_size,
+    unsigned int width) :
+    Named(name),
+    cpu(cpu_),
+    inp(inp_),
+    outWire(out_.inputWire),
+    isTerminal(false),
+    nextStageReserve(&next_stage_input_buffer),
+    outputWidth(width),
+    stageInfo(params.numThreads),
+    threadPriority(0)
+{
+    if (outputWidth < 1)
+        fatal("%s: outputWidth must be >= 1 (%d)\n", name, outputWidth);
+
+    if (input_buffer_size < 1)
+        fatal("%s: inputBufferSize must be >= 1 (%d)\n", name,
+            input_buffer_size);
+
+    for (ThreadID tid = 0; tid < params.numThreads; tid++) {
+        inputBuffer.push_back(
+            InputBuffer<ForwardInstData>(
+                name + ".inputBuffer" + std::to_string(tid), "insts",
+                input_buffer_size));
+    }
+}
+
+PassthroughStage::PassthroughStage(const std::string &name,
+    MinorCPU &cpu_,
+    const BaseMinorCPUParams &params,
+    Latch<ForwardInstData>::Output inp_,
+    unsigned int input_buffer_size,
+    unsigned int width) :
+    Named(name),
+    cpu(cpu_),
+    inp(inp_),
+    outWire(),
+    isTerminal(true),
+    nextStageReserve(nullptr),
+    outputWidth(width),
+    stageInfo(params.numThreads),
+    threadPriority(0)
+{
+    if (input_buffer_size < 1)
+        fatal("%s: inputBufferSize must be >= 1 (%d)\n", name,
+            input_buffer_size);
+
+    for (ThreadID tid = 0; tid < params.numThreads; tid++) {
+        inputBuffer.push_back(
+            InputBuffer<ForwardInstData>(
+                name + ".inputBuffer" + std::to_string(tid), "insts",
+                input_buffer_size));
+    }
+}
+
+const ForwardInstData *
+PassthroughStage::getInput(ThreadID tid)
+{
+    if (!inputBuffer[tid].empty()) {
+        const ForwardInstData &head = inputBuffer[tid].front();
+        return (head.isBubble() ? NULL : &(inputBuffer[tid].front()));
+    } else {
+        return NULL;
+    }
+}
+
+void
+PassthroughStage::popInput(ThreadID tid)
+{
+    if (!inputBuffer[tid].empty())
+        inputBuffer[tid].pop();
+}
+
+ThreadID
+PassthroughStage::getScheduledThread()
+{
+    std::vector<ThreadID> priority_list;
+
+    switch (cpu.threadPolicy) {
+      case enums::SingleThreaded:
+        priority_list.push_back(0);
+        break;
+      case enums::RoundRobin:
+        priority_list = cpu.roundRobinPriority(threadPriority);
+        break;
+      case enums::Random:
+        priority_list = cpu.randomPriority();
+        break;
+      default:
+        panic("Unknown thread policy");
+    }
+
+    for (auto tid : priority_list) {
+        if (getInput(tid)) {
+            if (isTerminal) {
+                /* Terminal stage: always accept if there's input */
+                threadPriority = tid;
+                return tid;
+            }
+            if ((*nextStageReserve)[tid].canReserve()) {
+                threadPriority = tid;
+                return tid;
+            }
+        }
+    }
+
+    return InvalidThreadID;
+}
+
+void
+PassthroughStage::evaluate()
+{
+    /* Push input from the latch onto the input buffer */
+    if (!inp.outputWire->isBubble())
+        inputBuffer[inp.outputWire->threadId].setTail(*inp.outputWire);
+
+    if (!isTerminal) {
+        /* Non-terminal: forward data to output latch */
+        ForwardInstData &insts_out = *outWire;
+        assert(insts_out.isBubble());
+
+        /* Check if next stage can accept data */
+        for (ThreadID t = 0; t < cpu.numThreads; t++)
+            stageInfo[t].blocked = !(*nextStageReserve)[t].canReserve();
+
+        ThreadID tid = getScheduledThread();
+
+        if (tid != InvalidThreadID) {
+            const ForwardInstData *insts_in = getInput(tid);
+
+            if (insts_in) {
+                unsigned int num_to_forward = insts_in->width();
+                if (num_to_forward > outputWidth)
+                    num_to_forward = outputWidth;
+
+                insts_out.resize(outputWidth);
+                for (unsigned int i = 0; i < num_to_forward; i++) {
+                    insts_out.insts[i] = insts_in->insts[i];
+                }
+                insts_out.threadId = tid;
+
+                DPRINTF(MinorTrace, "Forwarding %d insts from %s\n",
+                    num_to_forward, name());
+
+                popInput(tid);
+            }
+        }
+
+        /* If we generated output, reserve space and mark activity */
+        if (!insts_out.isBubble()) {
+            cpu.activityRecorder->activity();
+            insts_out.threadId = tid;
+            (*nextStageReserve)[tid].reserve();
+        }
+    } else {
+        /* Terminal stage: just consume input (modeling pipeline depth) */
+        ThreadID tid = getScheduledThread();
+
+        if (tid != InvalidThreadID) {
+            DPRINTF(MinorTrace, "Consuming insts in terminal %s\n", name());
+            popInput(tid);
+            cpu.activityRecorder->activity();
+        }
+    }
+
+    /* If we still have input and somewhere to put it, stay active */
+    for (ThreadID i = 0; i < cpu.numThreads; i++) {
+        if (getInput(i)) {
+            if (isTerminal || (*nextStageReserve)[i].canReserve()) {
+                cpu.activityRecorder->activateStage(Pipeline::CPUStageId);
+                break;
+            }
+        }
+    }
+
+    /* Push remaining input tail */
+    if (!inp.outputWire->isBubble())
+        inputBuffer[inp.outputWire->threadId].pushTail();
+}
+
+bool
+PassthroughStage::isDrained()
+{
+    for (const auto &buffer : inputBuffer) {
+        if (!buffer.empty())
+            return false;
+    }
+    return (*inp.outputWire).isBubble();
+}
+
+void
+PassthroughStage::minorTrace() const
+{
+    std::ostringstream data;
+
+    if (!isTerminal && stageInfo[0].blocked)
+        data << 'B';
+    else if (!isTerminal)
+        (*outWire).reportData(data);
+    else
+        data << "terminal";
+
+    minor::minorTrace("insts=%s\n", data.str());
+    inputBuffer[0].minorTrace();
+}
+
+} // namespace minor
+} // namespace gem5
