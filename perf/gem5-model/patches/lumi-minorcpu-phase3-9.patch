+++ b/src/arch/riscv/isa/formats/zext.isa
@@ -0,0 +1,71 @@
+// -*- mode:c++ -*-
+
+// Format definitions for Zimop, Zcmt, and Zcmop extensions
+// These are May-Be-Operations (MOPs) and table jump instructions
+
+// Custom declare template with generateDisassembly override
+def template ZextDeclare {{
+    //
+    // Static instruction class for "%(mnemonic)s".
+    //
+    class %(class_name)s : public %(base_class)s
+    {
+      private:
+        %(reg_idx_arr_decl)s;
+
+      public:
+        /// Constructor.
+        %(class_name)s(ExtMachInst machInst);
+        Fault execute(ExecContext *, trace::InstRecord *) const override;
+        std::string generateDisassembly(
+                Addr pc, const loader::SymbolTable *symtab) const override;
+    };
+}};
+
+// Custom execute template with simple disassembly
+def template ZextExecute {{
+    Fault
+    %(class_name)s::execute(ExecContext *xc,
+        trace::InstRecord *traceData) const
+    {
+        %(op_decl)s;
+        %(op_rd)s;
+        %(code)s;
+        %(op_wb)s;
+        return NoFault;
+    }
+
+    std::string
+    %(class_name)s::generateDisassembly(
+            Addr pc, const loader::SymbolTable *symtab) const
+    {
+        return mnemonic;
+    }
+}};
+
+// Zimop MOP format - writes 0 to rd (default NOP-like behavior)
+def format MopRn(code, *flags) {{
+    iop = InstObjParams(name, Name, 'RiscvStaticInst', code, flags)
+    header_output = ZextDeclare.subst(iop)
+    decoder_output = BasicConstructor.subst(iop)
+    decode_block = BasicDecode.subst(iop)
+    exec_output = ZextExecute.subst(iop)
+}};
+
+// Zcmt cm.jt format - table jump without link
+def format CmJt(code, *flags) {{
+    iop = InstObjParams(name, Name, 'RiscvStaticInst', code, flags)
+    header_output = ZextDeclare.subst(iop)
+    decoder_output = BasicConstructor.subst(iop)
+    decode_block = BasicDecode.subst(iop)
+    exec_output = ZextExecute.subst(iop)
+}};
+
+// Zcmt cm.jalt format - table jump with link
+def format CmJalt(code, *flags) {{
+    iop = InstObjParams(name, Name, 'RiscvStaticInst', code, flags)
+    header_output = ZextDeclare.subst(iop)
+    decoder_output = BasicConstructor.subst(iop)
+    decode_block = BasicDecode.subst(iop)
+    exec_output = ZextExecute.subst(iop)
+}};
